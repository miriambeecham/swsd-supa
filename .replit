# .replit — minimal + works with the Run button

modules = ["nodejs-20", "web"]

# Legacy runner fallback (some workspaces still use this)
run = "npm run dev"

[nix]
channel = "stable-25_05"

# Optional deployment settings (fine to keep)
[deployment]
build = ["sh", "-c", "npm ci && npm run build"]
run   = ["sh", "-c", "node server.js"]
deploymentTarget = "cloudrun"

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 5173
externalPort = 80

# Minimal Workflows block so the UI has a "Run Button" target
[workflows]
runButton = "Development"

[[workflows.workflow]]
name = "Development"
mode = "parallel"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"

[agent]
expertMode = true

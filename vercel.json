{
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/zoho-sync-final",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/send-morning-email-reminders",
      "schedule": "0 16 * * *"
    },
    {
      "path": "/api/send-afternoon-sms-reminders",
      "schedule": "0 22 * * *"
    },
    {
      "path": "/api/send-preclass-sms-reminders",
      "schedule": "0,15,30,45 * * * *"
    },
    {
      "path": "/api/send-class-followup",
      "schedule": "0,30 * * * *"
    }
  ]
}

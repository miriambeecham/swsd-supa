{
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/zoho-sync-final",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/send-class-reminders",
      "schedule": "0 15 * * *"
    },
    {
      "path": "/api/send-class-followup",
      "schedule": "*/15 * * * *"
    }
  ]
}
